        <untitled-ontology-14:definicion>Métrica para traducción automática</untitled-ontology-14:definicion>
        <untitled-ontology-14:nombre>BLEU Score</untitled-ontology-14:nombre>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_F1 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_F1">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#Metrica"/>
        <untitled-ontology-14:definicion>Media armónica entre precisión y recall</untitled-ontology-14:definicion>
        <untitled-ontology-14:formula>2*(P*R)/(P+R)</untitled-ontology-14:formula>
        <untitled-ontology-14:nombre>F1 Score</untitled-ontology-14:nombre>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_MAE -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_MAE">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#Metrica"/>
        <untitled-ontology-14:definicion>Error absoluto medio</untitled-ontology-14:definicion>
        <untitled-ontology-14:formula>(1/n)Σ|yi-ŷi|</untitled-ontology-14:formula>
        <untitled-ontology-14:nombre>Mean Absolute Error</untitled-ontology-14:nombre>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_MSE -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_MSE">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#Metrica"/>
        <untitled-ontology-14:definicion>Error cuadrático medio para regresión</untitled-ontology-14:definicion>
        <untitled-ontology-14:formula>(1/n)Σ(yi-ŷi)²</untitled-ontology-14:formula>
        <untitled-ontology-14:nombre>Mean Squared Error</untitled-ontology-14:nombre>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_Perplexity -->

