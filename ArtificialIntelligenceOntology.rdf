    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_Precision -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#met_Precision">
        <rdf:type rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/3/untitled-ontology-14#Metrica"/>
        <untitled-ontology-14:definicion>Verdaderos positivos sobre total de positivos predichos</untitled-ontology-14:definicion>
        <untitled-ontology-14:formula>TP/(TP+FP)</untitled-ontology-14:formula>
